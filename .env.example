# Crisis Monitor - .env.example
#
# Copy this file to `.env.local` for local development.
#
# IMPORTANT:
# - All keys below are optional. The dashboard should still run without them.
# - Keys are only read on the server (Vercel Edge / serverless functions).
# - Never expose these values to the frontend.

# --- AI / Summarization ------------------------------------------------------

# Groq LLM API (optional)
# What it does: enables fast LLM-based summarization / briefing (if wired).
# Where to get it: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter API (optional)
# What it does: LLM provider gateway (route prompts to multiple models).
# Where to get it: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI API (optional)
# What it does: powers `/api/ai/brief` when enabled (otherwise the app returns a fallback brief).
# Where to get it: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Markets -----------------------------------------------------------------

# Finnhub API (optional)
# What it does: financial market data (quotes, etc.) for risk context.
# Where to get it: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- Geopolitics / Conflict Data --------------------------------------------

# ACLED access token (optional)
# What it does: Global conflict / political violence dataset access.
# Where to get it: https://acleddata.com/data-export-tool/
ACLED_ACCESS_TOKEN=

# --- Caching -----------------------------------------------------------------

# Upstash Redis REST URL (optional)
# What it does: server-side caching / rate-limit protection for API fetchers.
# Where to get it: https://console.upstash.com/ (Redis database -> REST API section)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token (optional)
# What it does: authenticates REST access to Upstash Redis.
# Where to get it: https://console.upstash.com/ (Redis database -> REST API section)
UPSTASH_REDIS_REST_TOKEN=
